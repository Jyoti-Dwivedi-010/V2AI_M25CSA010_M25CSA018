# .env.secrets.example
# Copy this to .env.secrets and fill in your real values.
# Then run: source .env.secrets before docker-compose commands.
# NEVER commit .env.secrets to git.

# HuggingFace token (get from: https://huggingface.co/settings/tokens)
export HF_TOKEN=hf_your_token_here

# WandB API key (get from: https://wandb.ai/settings)
export WANDB_API_KEY=wandb_v1_your_key_here
