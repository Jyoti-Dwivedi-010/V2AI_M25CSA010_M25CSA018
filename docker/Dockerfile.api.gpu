# Dockerfile.api.gpu
# Base: pytorch/pytorch:latest — already has GPU torch, confirmed working on this server.
#
# KEY DESIGN DECISION:
# We do NOT reinstall torch from PyPI. requirements.txt has 'torch>=2.4' which pip
# resolves to the CPU-only package from PyPI (index.pypi.org), overwriting the GPU
# torch in the base image. We strip that line before pip install.
# sentence-transformers and openai-whisper also depend on torch, but pip will see
# the base image's conda-installed torch as satisfying those constraints and skip it.

FROM pytorch/pytorch:latest

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    NVIDIA_VISIBLE_DEVICES=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg curl git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .

# Strip torch* lines — base image already provides GPU-capable torch.
# Pip will see the existing conda torch as satisfying transitive torch deps
# (sentence-transformers needs torch>=1.11, openai-whisper needs torch>=1.7)
# and will NOT reinstall it from PyPI.
RUN sed '/^torch/d' requirements.txt > /tmp/req.txt \
    && pip install --upgrade pip \
    && pip install -r /tmp/req.txt \
    && pip install faiss-cpu

# NOTE: No build-time 'import torch' check here.
# CUDA devices (and libcuda.so) are not available during 'docker build'.
# The GPU test is done at container startup via docker exec.

COPY src/ ./src/
COPY data/ ./data/

RUN mkdir -p artifacts/uploads artifacts/transcripts artifacts/vectorstore \
    artifacts/monitoring artifacts/reports artifacts/mlflow

ENV PYTHONPATH=/app/src
EXPOSE 8000

CMD ["uvicorn", "app.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
