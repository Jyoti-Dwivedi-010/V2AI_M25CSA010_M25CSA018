# Dockerfile.api.gpu
# Uses pytorch/pytorch:latest (already cached on server, confirmed CUDA working)
# Forces GPU torch reinstall after all deps to prevent CPU-only overwrites

FROM pytorch/pytorch:latest

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    NVIDIA_VISIBLE_DEVICES=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg curl git build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .

# Install all app requirements
# Note: packages like openai-whisper / sentence-transformers may silently
# install CPU-only torch as a transitive dependency.
RUN pip install --upgrade pip \
    && pip install -r requirements.txt \
    && pip install faiss-gpu 2>/dev/null || pip install faiss-cpu

# ── GPU torch restore ─────────────────────────────────────────────────────
# Reinstall torch with CUDA after all deps, to override any CPU-only version.
# pytorch/pytorch:latest is built with CUDA 12.1 libraries.
RUN pip install --force-reinstall --no-deps \
    "torch" \
    --index-url https://download.pytorch.org/whl/cu121

# Build-time sanity check — verifies torch has CUDA support compiled in.
# (GPU devices are not available during build, but torch.version.cuda is.)
RUN python3 -c "
import torch
print('Torch version:', torch.__version__)
print('CUDA built for:', torch.version.cuda)
assert torch.version.cuda is not None, 'ERROR: CPU-only torch still installed!'
print('OK: torch is CUDA-capable')
"

COPY src/ ./src/
COPY data/ ./data/

RUN mkdir -p artifacts/uploads artifacts/transcripts artifacts/vectorstore \
    artifacts/monitoring artifacts/reports artifacts/mlflow

ENV PYTHONPATH=/app/src
EXPOSE 8000

CMD ["uvicorn", "app.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
