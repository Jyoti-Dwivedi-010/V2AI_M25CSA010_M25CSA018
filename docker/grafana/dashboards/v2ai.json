{
  "uid": "v2ai-main",
  "title": "V2AI — Lecture Intelligence Dashboard",
  "tags": ["v2ai", "mlops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Ask Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "v2ai_ask_requests_total",
          "legendFormat": "Ask Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "blue", "value": 0}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Upload Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "v2ai_upload_requests_total",
          "legendFormat": "Uploads"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ask Latency (p95) seconds",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(v2ai_ask_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "Ask Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "rate(v2ai_ask_requests_total[1m]) * 60",
          "legendFormat": "Ask req/min"
        },
        {
          "expr": "rate(v2ai_upload_requests_total[1m]) * 60",
          "legendFormat": "Upload req/min"
        }
      ]
    },
    {
      "id": 5,
      "title": "Ask Latency Histogram",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(v2ai_ask_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(v2ai_ask_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(v2ai_ask_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
